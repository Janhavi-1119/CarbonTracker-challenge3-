# Environment Variables Example Configuration
# Rename this file to .env and populate the actual values.
# IMPORTANT: Never commit actual .env files containing secrets to version control.

# Example API Keys (If integrating external services like Firebase or footprint databases)
VITE_APP_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_APP_FIREBASE_PROJECT_ID=your_project_id_here
VITE_APP_MAP_SERVICE_KEY=your_map_service_key_here

# App Configuration
VITE_APP_ENV=development
VITE_APP_VERSION=5.0.0
